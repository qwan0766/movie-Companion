# ── LLM 配置 ──────────────────────────────────────────
# 是否启用 LLM（true=启用AI，false=使用规则，默认false）
LLM_ENABLED=false
# LLM 提供商: deepseek / openai（默认 deepseek）
LLM_PROVIDER=deepseek
# API Key（DeepSeek / OpenAI）
LLM_API_KEY=sk-your-key-here
# 模型名（DeepSeek: deepseek-v4-flash, OpenAI: gpt-4o-mini 等）
LLM_MODEL=deepseek-v4-flash
# API 地址（DeepSeek: https://api.deepseek.com/v1, OpenAI: https://api.openai.com/v1）
LLM_BASE_URL=https://api.deepseek.com/v1
# 生成温度（0.0-1.0，默认 0.1）
LLM_TEMPERATURE=0.1

# ── LangSmith 追踪 ────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__your_api_key_here
LANGCHAIN_PROJECT=tencent_video_agent

# ── Neo4j 知识图谱 ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── 数据库路径 ────────────────────────────────────────
SQLITE_DB_PATH=data/tencent_video.db
CHROMA_PERSIST_DIR=data/chroma_db
